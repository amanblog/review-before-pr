{
  "version": "1.0",
  "baseBranch": "main",
  "ignorePatterns": [
    "*.lock",
    "dist/*",
    "*.min.js",
    "*.generated.ts",
    "migrations/*"
  ],
  "additionalExcludes": [],
  "secretPatterns": {
    "enabled": true,
    "customPatterns": []
  },
  "review": {
    "categories": [
      "security",
      "performance",
      "maintainability"
    ],
    "commentPriorities": true,
    "contextGathering": true
  },
  "output": {
    "format": "markdown",
    "includeMetrics": true,
    "timestampReports": true
  },
  "patches": {
    "autoGenerate": false,
    "requireConfirmation": true
  },
  "prComments": {
    "enabled": true,
    "signature": "🔍 *Posted by [review-before-pr](https://github.com/amanblog/review-before-pr) — AI-assisted review*",
    "defaultMode": "select"
  },
  "multiPass": {
    "enabled": true,
    "skipBelowLines": 100
  },
  "projectConventions": {
    "_comment": "Repo-specific hints the reviewer should prefer. Leave arrays empty if not applicable. The reviewer flags when the diff reinvents anything listed here.",
    "preferredComponents": {
      "_comment": "Canonical shared components. If the diff builds a custom version of one of these, flag it.",
      "Button": "CustomButton",
      "Table": "CustomTable",
      "Dialog": "Dialog",
      "InfoRow": "InfoRow"
    },
    "singletons": [
      "shared/services/instance"
    ],
    "helpers": {
      "_comment": "Canonical helpers that frequently get reimplemented inline.",
      "isRtl": "isArabicLocale",
      "socialHref": "buildSocialHref"
    },
    "constants": [
      "STORE_DOMAIN",
      "CURRENCY_OPTIONS",
      "CourseSortBy"
    ],
    "locales": ["en", "ar"],
    "isNextJs": false,
    "importStyle": "absolute",
    "pathAlias": "@/"
  }
}
